# Environment Configuration Template
# Copy this file to .env and configure with your values

# Credentials encryption password
# This password is used to encrypt/decrypt credentials stored in the database
# Keep this secure and never commit the actual .env file to version control
CREDENTIALS_PASSWORD=your_secure_password_here_change_me

# Path to SOUL.md file (system instructions and behavior guidelines)
# Default: persistent/SOUL.md
SOUL_PATH=persistent/SOUL.md

# Path to USER.md file (user information and preferences)
# Default: persistent/USER.md
USER_PATH=persistent/USER.md

# Path to MEMORY.md file (important context to remember)
# Default: persistent/MEMORY.md
MEMORY_PATH=persistent/MEMORY.md

# Path to credentials database
# Default: persistent/credentials.db
CREDENTIALS_DB_PATH=persistent/credentials.db
