# Environment Configuration Template
# Copy this file to .env and configure with your values

# ===================
# AI-ONE Configuration
# ===================

# Debug mode - shows detailed logging for development and troubleshooting
# Set to 1 to enable comprehensive debug logging
DEBUG=1

# Default LLM model to use
# MODEL=gpt-4.1

# Default LLM provider  
# PROVIDER=copilot

# Maximum tool execution loops per request
# MAX_TOOL_ITERATIONS=5

# ===================
# Tool Configuration
# ===================

# Credentials encryption password
# This password is used to encrypt/decrypt credentials stored in the database
# Keep this secure and never commit the actual .env file to version control
CREDENTIALS_PASSWORD=your_secure_password_here_change_me

# Path to SOUL.md file (system instructions and behavior guidelines)
# Default: persistent/SOUL.md
SOUL_PATH=persistent/SOUL.md

# Path to USER.md file (user information and preferences)
# Default: persistent/USER.md
USER_PATH=persistent/USER.md

# Path to MEMORY.md file (important context to remember)
# Default: persistent/MEMORY.md
MEMORY_PATH=persistent/MEMORY.md

# Path to credentials database
# Default: persistent/credentials.db
CREDENTIALS_DB_PATH=persistent/credentials.db

# ===================
# API Keys & External Services
# ===================

# Tavily AI Web Search API Key
# Get from: https://app.tavily.com/
# TAVILY_API_KEY=your_tavily_api_key_here

# Google Workspace API Configuration
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CREDENTIALS_PATH=persistent/google_credentials.json
GOOGLE_TOKEN_PATH=persistent/google_token.json

# Facebook Messenger Configuration
# Get Page Access Token from: https://developers.facebook.com/
MESSENGER_PAGE_ACCESS_TOKEN=your_page_access_token_here
MESSENGER_PAGE_ID=your_page_id_here
